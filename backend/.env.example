PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/takhet
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
GEMINI_API_KEY=replace-with-gemini-api-key
KASPI_MERCHANT_ID=replace-with-kaspi-merchant-id
KASPI_SECRET_KEY=replace-with-kaspi-secret-key
KASPI_API_URL=https://kaspi.kz/pay/api
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=replace-with-admin-password
APP_DOCTOR_EMAIL=doctor@example.com
APP_DOCTOR_PASSWORD=replace-with-doctor-password
APP_PARTNER_EMAIL=partner@example.com
APP_PARTNER_PASSWORD=replace-with-partner-password
APP_PATIENT_EMAIL=patient@example.com
APP_PATIENT_PASSWORD=replace-with-patient-password
APP_JWT_SECRET=replace-with-strong-secret
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=30

# LiveKit Cloud
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
LIVEKIT_PROJECT_ID=replace-with-livekit-project-id
LIVEKIT_SIP_URI=sip:your-livekit-sip-uri

SENTRY_DSN=
PII_ENCRYPTION_KEY=replace-with-32-byte-encryption-key

# auto move doctor_earnings from hold -> ready_for_payout
PAYOUT_AUTO_PREPARE_ENABLED=false
PAYOUT_AUTO_PREPARE_INTERVAL_MS=300000
PAYOUT_REVERSAL_WINDOW_DAYS=7
